+# Android aarch64 cross-compilation toolchain for Bun
+# Uses Android NDK clang toolchain targeting Bionic libc
+
+set(CMAKE_SYSTEM_NAME Android)
+set(CMAKE_SYSTEM_PROCESSOR aarch64)
+set(ABI android)
+
+# Android API level (24 = Android 7.0 Nougat — minimum for 64-bit Termux)
+set(ANDROID_PLATFORM 24)
+set(ANDROID_API_LEVEL 24)
+set(CMAKE_SYSTEM_VERSION ${ANDROID_API_LEVEL})
+set(CMAKE_ANDROID_ARCH_ABI arm64-v8a)
+
+# NDK path — override with -DANDROID_NDK_HOME=<path> if needed
+# Must survive re-processing in try_compile contexts
+if(NOT DEFINED ANDROID_NDK_HOME)
+  if(DEFINED CMAKE_ANDROID_NDK)
+    set(ANDROID_NDK_HOME "${CMAKE_ANDROID_NDK}")
+  elseif(DEFINED ENV{ANDROID_NDK_HOME})
+    set(ANDROID_NDK_HOME "$ENV{ANDROID_NDK_HOME}")
+  elseif(DEFINED ENV{ANDROID_NDK})
+    set(ANDROID_NDK_HOME "$ENV{ANDROID_NDK}")
+  else()
+    message(FATAL_ERROR "ANDROID_NDK_HOME is not set. Point it to your Android NDK installation.")
+  endif()
+endif()
+
+# Ensure this variable is forwarded to try_compile() sub-projects
+list(APPEND CMAKE_TRY_COMPILE_PLATFORM_VARIABLES ANDROID_NDK_HOME)
+
+set(CMAKE_ANDROID_NDK ${ANDROID_NDK_HOME})
+
+set(NDK_TOOLCHAIN "${ANDROID_NDK_HOME}/toolchains/llvm/prebuilt/linux-x86_64")
+set(NDK_SYSROOT "${NDK_TOOLCHAIN}/sysroot")
+set(ANDROID_TRIPLE "aarch64-linux-android")
+set(ANDROID_TRIPLE_API "${ANDROID_TRIPLE}${ANDROID_API_LEVEL}")
+
+# Tell CMake to use the NDK sysroot
+set(CMAKE_SYSROOT "${NDK_SYSROOT}")
+
+# Set compilers from NDK
+set(CMAKE_C_COMPILER "${NDK_TOOLCHAIN}/bin/${ANDROID_TRIPLE_API}-clang")
+set(CMAKE_CXX_COMPILER "${NDK_TOOLCHAIN}/bin/${ANDROID_TRIPLE_API}-clang++")
+set(CMAKE_ASM_COMPILER "${NDK_TOOLCHAIN}/bin/${ANDROID_TRIPLE_API}-clang")
+set(CMAKE_AR "${NDK_TOOLCHAIN}/bin/llvm-ar")
+set(CMAKE_RANLIB "${NDK_TOOLCHAIN}/bin/llvm-ranlib")
+set(CMAKE_STRIP "${NDK_TOOLCHAIN}/bin/llvm-strip")
+set(CMAKE_NM "${NDK_TOOLCHAIN}/bin/llvm-nm")
+set(CMAKE_LINKER "${NDK_TOOLCHAIN}/bin/ld.lld")
+set(CMAKE_OBJCOPY "${NDK_TOOLCHAIN}/bin/llvm-objcopy")
+set(CMAKE_OBJDUMP "${NDK_TOOLCHAIN}/bin/llvm-objdump")
+
+# Skip compiler checks — we know the cross compiler works
+set(CMAKE_C_COMPILER_WORKS ON)
+set(CMAKE_CXX_COMPILER_WORKS ON)
+
+# Search paths: only look in the sysroot for libraries/headers, not on the host
+set(CMAKE_FIND_ROOT_PATH "${NDK_SYSROOT}")
+set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
+set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
+set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
+set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
